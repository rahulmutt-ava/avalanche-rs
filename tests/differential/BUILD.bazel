load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "ava_differential",
    srcs = [
        "src/driver.rs",
        "src/lib.rs",
        "src/network.rs",
        "src/observation.rs",
        "src/program.rs",
    ],
    compile_data = ["Cargo.toml"],
    visibility = ["//visibility:public"],
    deps = ["@crates//:arbitrary"],
)

rust_test(
    name = "smoke",
    srcs = ["tests/smoke.rs"],
    compile_data = ["Cargo.toml"],
    visibility = ["//visibility:public"],
    deps = [
        ":ava_differential",
        "@crates//:arbitrary",
    ],
)

rust_test(
    name = "interop_handshake",
    srcs = ["tests/interop_handshake.rs"],
    compile_data = [
        "Cargo.toml",
        "tests/fixtures/fuji_transcript.bin",
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":ava_differential",
        "//crates/ava-crypto:ava_crypto",
        "//crates/ava-message:ava_message",
        "//crates/ava-network:ava_network",
        "//crates/ava-types:ava_types",
        "//crates/ava-version:ava_version",
        "@crates//:tokio",
        "@crates//:tokio-util",
    ],
)
