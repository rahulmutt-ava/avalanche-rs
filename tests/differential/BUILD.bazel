load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "ava_differential",
    srcs = [
        "src/driver.rs",
        "src/lib.rs",
        "src/network.rs",
        "src/observation.rs",
        "src/program.rs",
