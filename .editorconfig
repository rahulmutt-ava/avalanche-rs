# https://editorconfig.org/
# See specs/01-development-environment.md §7.2.
root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 2

# Rust uses 4-space indentation (rustfmt default).
[*.rs]
indent_style = space
indent_size = 4

# Go (extract-vectors tooling) uses tabs.
[*.go]
indent_style = tab
