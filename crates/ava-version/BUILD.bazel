load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "ava_version",
    srcs = [
        "src/application.rs",
        "src/compatibility.rs",
        "src/error.rs",
        "src/lib.rs",
        "src/upgrade.rs",
    ],
    compile_data = ["Cargo.toml"],
    visibility = ["//visibility:public"],
    deps = [
        "//crates/ava-types:ava_types",
        "@crates//:bs58",
        "@crates//:chrono",
        "@crates//:serde",
        "@crates//:thiserror",
    ],
)

rust_test(
    name = "golden_upgrade",
