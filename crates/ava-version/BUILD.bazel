    compile_data = ["Cargo.toml"],
    visibility = ["//visibility:public"],
    deps = [
        ":ava_version",
        "//crates/ava-types:ava_types",
        "@crates//:chrono",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

rust_test(
    name = "proptests",
    srcs = ["tests/proptests.rs"],
    compile_data = ["Cargo.toml"],
    visibility = ["//visibility:public"],
    deps = [
        ":ava_version",
        "//crates/ava-types:ava_types",
        "@crates//:chrono",
        "@crates//:proptest",
    ],
)

rust_test(
    name = "version",
    srcs = ["tests/version.rs"],
    compile_data = ["Cargo.toml"],
    visibility = ["//visibility:public"],
    deps = [":ava_version"],
