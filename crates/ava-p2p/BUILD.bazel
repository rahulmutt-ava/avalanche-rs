load("@rules_rust//cargo:defs.bzl", "cargo_build_script")
load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")

rust_library(
    name = "ava_p2p",
    srcs = [
        "src/client.rs",
        "src/error.rs",
        "src/gossip/bloom.rs",
        "src/gossip/handler.rs",
        "src/gossip/mod.rs",
        "src/gossip/pull.rs",
        "src/gossip/push.rs",
        "src/handler.rs",
        "src/lib.rs",
        "src/network.rs",
        "src/pb.rs",
    ],
    compile_data = ["Cargo.toml"],
    proc_macro_deps = ["@crates//:async-trait"],
    visibility = ["//visibility:public"],
    deps = [
        ":build_script",
        "//crates/ava-types:ava_types",
        "//crates/ava-utils:ava_utils",
        "//crates/ava-version:ava_version",
        "//crates/ava-vm:ava_vm",
        "@crates//:bytes",
        "@crates//:parking_lot",
        "@crates//:prost",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:tokio-util",
        "@crates//:tracing",
    ],
)

