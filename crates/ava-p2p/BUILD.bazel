rust_test(
    name = "wire_goldens",
    srcs = ["tests/wire_goldens.rs"],
    compile_data = [
        "../../tests/vectors/p2p_sdk/pull_gossip_request.bin",
        "../../tests/vectors/p2p_sdk/pull_gossip_response.bin",
        "../../tests/vectors/p2p_sdk/push_gossip_frame.bin",
