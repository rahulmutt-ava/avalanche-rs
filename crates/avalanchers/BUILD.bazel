load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")

# NOTE: the M3 consensus/VM crates (ava-snow, ava-engine, ava-vm, ava-chains,
# ava-proposervm, ava-validators, …) do not yet ship BUILD.bazel files, so the
# in-process chain-manager lib + integration test below cannot be built under
# Bazel until those are generated (gazelle_rust). Tracked as M3.29 / Bazel
# metadata follow-up; Cargo is the source of truth in the interim.

rust_library(
    name = "avalanchers_lib",
    srcs = [
        "src/app.rs",
        "src/lib.rs",
        "src/wiring/chains.rs",
        "src/wiring/genesis_validator_state.rs",
        "src/wiring/mod.rs",
    ],
    compile_data = ["Cargo.toml"],
    crate_name = "avalanchers",
    proc_macro_deps = ["@crates//:async-trait"],
    visibility = ["//visibility:public"],
    deps = [
        "//crates/ava-api:ava_api",
        "//crates/ava-avm:ava_avm",
        "//crates/ava-chains:ava_chains",
        "//crates/ava-config:ava_config",
        "//crates/ava-crypto:ava_crypto",
        "//crates/ava-database:ava_database",
        "//crates/ava-engine:ava_engine",
